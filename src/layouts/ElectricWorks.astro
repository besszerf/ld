---
import {frontmatter, Content} from '../components/Villszer.md';
import { Image } from "astro:assets";
import fali_szerelveny from "../assets/images/IMG_6681.jpeg";

---

<!-- Promo Section - "We know design" -->
<a name="villszer"></a>
<div class="w3-container w3-light-grey" style="padding:32px 16px">
  <div class="w3-row-padding">
    <div class="w3-col m6 auto-show" style="padding:32px 16px">
      <div class="">
        <h3>{frontmatter.title}</h3>
        <Content />
      </div>
      <div class="w3-center w3-text-black" style="padding:32px 16px"><a href="#kapcsolat" class="w3-btn w3-ld-yellow w3-padding-large w3-large w3-margin-top w3-hover-opacity w3-animate-top">Kapcsolat felvétel</a></div>
    </div>
    <div class="w3-col m6 image-reveal" style="padding:32px 16px">
      <Image onclick="onClick(this)" class="w3-image w3-round-large w3-hover-opacity" src={fali_szerelveny} alt="Fali Szerelvény" width="600" />
    </div>
  </div>
</div>

<style>
.bf-animate-left {
  position: relative;
  left: -300px;
  opacity: 0;
}

.bf-animate-left.animateleft-trigger {
  animation: animateleft 0.4s forwards;
}

@keyframes animateleft {
  from {
    left: -300px;
    opacity: 0;
  }
  to {
    left: 0;
    opacity: 1;
  }
}

.bf-animate-right {
  position: relative;
  right: -300px;
  opacity: 0;
}

.bf-animate-right.animateright-trigger {
  animation: animateright 0.4s forwards;
}

@keyframes animateright {
  from {
    right: -300px;
    opacity: 0;
  }
  to {
    right: 0;
    opacity: 1;
  }
}
</style>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {
  const elements = document.querySelectorAll(".bf-animate-left");

  const observer = new IntersectionObserver(function(entries, observer) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add("animateleft-trigger");
      } else {
        entry.target.classList.remove("animateleft-trigger");
      }
    });
  },
  {
    threshold: 0.2
  });

  elements.forEach(function(el) {
    observer.observe(el);
  });

  const relements = document.querySelectorAll(".bf-animate-right");

  const robserver = new IntersectionObserver(function(entries, robserver) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add("animateright-trigger");
      } else {
        entry.target.classList.remove("animateright-trigger");
      }
    });
  },
  {
    threshold: 0.2
  });

  relements.forEach(function(el) {
    robserver.observe(el);
  });

});

</script>