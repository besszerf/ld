<!doctype html>
<html lang="hu">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="keywords" content="villanyszerelés, villanyszerelő, klímaszerelés, érintésvédelmi felülvizsgálat, E.ON regisztrált szerelő, Pécs, Mohács, Baranya megye">
    <meta name="description" content="Lelkes Dávid villanyszerelő vállalkozása, teljes körű villanyszerelés, klímaszerelés, érintésvédelmi felülvizsgálat és E.ON regisztrált szerelő szolgáltatásokkal Pécs, Mohács és Baranya megye területén. Szakértelem, precizitás és megbízhatóság a villanyszerelésben.">
		<link rel="stylesheet" href="./w3.css">
		<link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Raleway">
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
		<link rel="icon" href="./icon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>LD VillSzer Kft.</title>
	</head>
	<body>
		<slot />

		<!-- Modal for full size images on click-->
		<div id="modal01" class="w3-modal w3-black" onclick="this.style.display='none'">
			<span class="w3-button w3-xxlarge w3-black w3-padding-large w3-display-topright" title="Close Modal Image">×</span>
			<div class="w3-modal-content w3-animate-zoom w3-center w3-transparent w3-padding-64">
				<img id="img01" class="w3-image">
				<p id="caption" class="w3-opacity w3-large"></p>
			</div>
		</div>
		<script is:inline>
			// Modal Image Gallery
				function onClick(element) {
					document.getElementById("img01").src = element.src;
					document.getElementById("modal01").style.display = "block";
					var captionText = document.getElementById("caption");
					captionText.innerHTML = element.alt;
				}
		</script>
		<script>
		(() => {
			const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

			const effects = {
				text: {
					selector: ".auto-show",
					defaults: {
						startOffset: 1.0,
						endOffset: 0.55
					},
					getProgress(el, settings, viewportHeight) {
						const rect = el.getBoundingClientRect();
						const startY = viewportHeight * settings.startOffset;
						const endY = viewportHeight * settings.endOffset;
						return clamp((startY - rect.top) / (startY - endY), 0, 1);
					},
					render(el, progress) {
						const y = (1 - progress) * 120;
						el.style.opacity = progress.toFixed(3);
						el.style.transform = `translateY(${y.toFixed(2)}px)`;
					}
				},

				image: {
					selector: ".image-reveal",
					defaults: {
						startOffset: 0.95,
						endOffset: 0.45
					},
					getProgress(el, settings, viewportHeight) {
						const rect = el.getBoundingClientRect();
						const startY = viewportHeight * settings.startOffset;
						const endY = viewportHeight * settings.endOffset;
						return clamp((startY - rect.top) / (startY - endY), 0, 1);
					},
					render(el, progress) {
						const translateYRem = (1 - progress) * 4;
						const scale = 0.95 + progress * 0.05;
						const saturate = progress;
						const contrast = 4 - progress * 3;
						const brightness = 0.1 + progress * 0.9;
						const blur = (1 - progress) * 5;

						el.style.opacity = progress.toFixed(3);
						el.style.transform = `translateY(${translateYRem.toFixed(3)}rem) scale(${scale.toFixed(4)})`;
						el.style.filter = `saturate(${saturate.toFixed(3)}) contrast(${contrast.toFixed(3)}) brightness(${brightness.toFixed(3)}) blur(${blur.toFixed(3)}px)`;
					}
				}
			};

			const items = [];
			const active = new Set();

			for (const [type, effect] of Object.entries(effects)) {
				document.querySelectorAll(effect.selector).forEach((el) => {
					items.push({
						el,
						type,
						startOffset: parseFloat(el.dataset.startOffset ?? effect.defaults.startOffset),
						endOffset: parseFloat(el.dataset.endOffset ?? effect.defaults.endOffset)
					});
				});
			}

			if (!items.length) return;

			let viewportHeight = window.innerHeight || document.documentElement.clientHeight;
			let ticking = false;

			function renderItem(item) {
				const effect = effects[item.type];
				const progress = effect.getProgress(item.el, item, viewportHeight);
				effect.render(item.el, progress);
			}

			function updateActive() {
				ticking = false;
				active.forEach(renderItem);
			}

			function requestTick() {
				if (!ticking) {
					ticking = true;
					requestAnimationFrame(updateActive);
				}
			}

			const observer = new IntersectionObserver((entries) => {
				entries.forEach((entry) => {
					const item = items.find(i => i.el === entry.target);
					if (!item) return;

					if (entry.isIntersecting) {
						active.add(item);
					} else {
						active.delete(item);
					}

					renderItem(item);
				});
			}, {
				root: null,
				rootMargin: "20% 0px 20% 0px",
				threshold: 0
			});

			items.forEach((item) => {
				observer.observe(item.el);
				renderItem(item);
			});

			function onResize() {
				viewportHeight = window.innerHeight || document.documentElement.clientHeight;
				items.forEach(renderItem);
				requestTick();
			}

			window.addEventListener("scroll", requestTick, { passive: true });
			window.addEventListener("resize", onResize, { passive: true });
			window.addEventListener("orientationchange", onResize, { passive: true });
		})();
		</script>
	</body>
</html>

